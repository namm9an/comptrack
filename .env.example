# ============================================================
# CompTrack — environment variables
# Copy to .env and fill in all values before starting.
# ============================================================

# LLM (OpenAI-compatible endpoint — your TIR GPU instance)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-instruct
LLM_CONTEXT_WINDOW=32768
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Google OAuth 2.0
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add authorised redirect URI: http://<VM-IP>:8081/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/auth/google/callback
ALLOWED_EMAIL_DOMAIN=e2enetworks.com

# Admin seeding — this email gets the admin role on first login
ADMIN_EMAIL=

# JWT signing key — REQUIRED, must be a strong random value
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Cookie security — set to "true" when serving over HTTPS
COOKIE_SECURE=false

# SearXNG (inside Docker network — do not change unless you move SearXNG)
SEARXNG_BASE_URL=http://searxng:8888
MAX_SEARCH_RESULTS=10

# IP restriction (comma-separated allowed client IPs; leave empty to disable)
# Example: ALLOWED_IPS=203.0.113.10,198.51.100.5
ALLOWED_IPS=

# Trusted reverse proxies for X-Forwarded-For (comma-separated IPs)
# Set to the Docker bridge IP / frontend container IP so XFF can be trusted.
# Example: TRUSTED_PROXIES=172.18.0.1,172.18.0.2
TRUSTED_PROXIES=

# App ports (must match docker-compose.yml)
BACKEND_PORT=8081
FRONTEND_PORT=3001

# Frontend URL (used for post-OAuth redirect)
FRONTEND_URL=http://localhost:3001

# CORS origins (comma-separated; must include frontend URL; never use *)
CORS_ORIGINS=http://localhost:3001
